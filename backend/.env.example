# ============================================================================
# 方·苑 FANGYUAN 后端环境变量
# ============================================================================

# 应用
NODE_ENV=development
PORT=3000
APP_NAME=FANGYUAN
APP_URL=http://localhost:3000

# 数据库
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=fangyuan
DB_PASSWORD=fangyuan_dev_pwd_change_me
DB_DATABASE=fangyuan
DB_SYNCHRONIZE=false
DB_LOGGING=true

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=change_me_in_production_at_least_64_chars_long_random_string_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# 文件上传
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE=5242880
# 或云存储
# STORAGE_PROVIDER=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BUCKET_NAME=
# AWS_REGION=

# 短信(Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# 推送(Firebase)
FCM_SERVER_KEY=

# Google Maps
GOOGLE_MAPS_API_KEY=

# 汇率 API
EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_API_URL=https://open.er-api.com/v6/latest

# CORS(前端地址,多个用逗号)
CORS_ORIGINS=http://localhost:3001,http://localhost:8080

# 限流
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# 日志
LOG_LEVEL=debug
